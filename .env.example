# Base URL of the deployed backend API (server.ts), e.g. https://your-app.herokuapp.com
# Leave empty for local development (the Express server serves the API on the same origin).
# Set this in Vercel so the deployed frontend can reach the Heroku backend.
VITE_API_BASE_URL=

# Firebase web client settings (existing storefront/admin authentication)
VITE_FIREBASE_API_KEY=AIzaSyAsSHLoiXR2st744-kQCxLYRVDcyvmLl-U
VITE_FIREBASE_AUTH_DOMAIN=shopping-cambodia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shopping-cambodia
VITE_FIREBASE_STORAGE_BUCKET=shopping-cambodia.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=409063563999
VITE_FIREBASE_APP_ID=1:409063563999:web:a008823b8cde486d69ff6a
VITE_FIREBASE_MEASUREMENT_ID=G-57FC3WD515

# Main Business Agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Admin backend boundary
ADMIN_API_KEY=replace-with-a-long-random-secret
