# Firebase web client settings (existing storefront/admin authentication)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Main Business Agent
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Admin backend boundary
ADMIN_API_KEY=replace-with-a-long-random-secret
VITE_ADMIN_API_KEY=replace-with-the-same-secret
VITE_ADMIN_USER=owner
VITE_ADMIN_ROLE=owner

# Telegram publishing. Live sends require both the token and explicit true flag.
TELEGRAM_BOT_TOKEN=
TELEGRAM_LIVE_SEND=false
TELEGRAM_WEBHOOK_SECRET=

# Phase 1 budget policy
MONTHLY_MARKETING_BUDGET=1000

# Server
PORT=3000
NODE_ENV=development
